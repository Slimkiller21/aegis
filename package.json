{
  "name": "nsfw-guard",
  "version": "0.6.0",
  "description": "Aegis — local, always-on desktop guard that detects on-screen NSFW content in real time and blocks it. Built to help people stay off compulsive habits. 100% offline — screen frames never leave the device. (package name kept as nsfw-guard so the userData folder — streaks, settings, lock password — survives the rebrand)",
  "main": "src/main/main.js",
  "author": "Slimkiller21",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "icon": "python scripts/make_icon.py",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "nodemailer": "^9.0.3",
    "onnxruntime-node": "^1.27.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.slimkiller.aegis",
    "productName": "Aegis",
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/@tensorflow/**",
      "!node_modules/nsfwjs/**"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/onnxruntime-node/**",
      "assets/models/**"
    ],
    "artifactName": "Aegis-Setup.exe",
    "publish": [
      {
        "provider": "github",
        "owner": "Slimkiller21",
        "repo": "aegis"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/uninstall-guard.nsh"
    }
  }
}
